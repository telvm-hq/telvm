# Private material under .internal/ — see .internal/README.md
# Tracked: .internal/README.md and .internal/architecture/ (versioned internal architecture notes)
.internal/*
!.internal/README.md
!.internal/architecture/
!.internal/architecture/**

# Elixir / Phoenix (companion app)
# Never commit build artifacts or deps — verify with: git status (should not list _build/ or deps/)
companion/_build/
companion/deps/
companion/.elixir_ls/
companion/*.beam
companion/*.ez
companion/erl_crash.dump
companion/*.plt
companion/*.plt.hash
companion/priv/static/assets/

# If you run npm/yarn on the host inside companion/assets/
companion/assets/node_modules/

# MCP package (Node / TypeScript)
mcp/node_modules/
mcp/dist/

# Environment
.env
.env.*
!.env.example

# Local LAN host inventories (may contain IPs, keys in notes)
inventories/lan-host/baseline.local.yaml
inventories/lan-host/*.local.txt

# Golden host profile exports (machine-specific; use capture-golden-profile.sh locally)
golden-profile-*/

# Docker
docker-compose.override.yml

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs & caches
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor
*.swp
*.swo
*~
.vscode/
.idea/

# DETS persistence files (future)
*.dets

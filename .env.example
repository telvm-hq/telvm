# Local `docker compose up` does NOT require a `.env` file — defaults live in docker-compose.yml
# (Postgres, companion, per-workload egress proxy, telvm_closed_claude / telvm_closed_codex).
# Uncomment or copy lines below only for optional overrides (API keys, cluster nodes, CI, etc.).

# Optional: provider API keys once a settings UI wires them in (agent-agnostic; v0.1.0 roadmap).
# ANTHROPIC_API_KEY=

# Override HTTP port inside the companion container (default 4000).
# PORT=4000

# Tests inside Compose (see README): prefer TEST_DATABASE_URL so Mix never uses the dev DB.
# TEST_DATABASE_URL=postgres://postgres:postgres@db:5432/companion_test

# Default OpenAI-compatible inference base for Agent setup (/v1). Compose sets http://ollama:11434/v1 on the companion.
# TELVM_INFERENCE_BASE_URL=http://ollama:11434/v1

# Default model id for Agent setup Model tab auto-session (must exist on Ollama). Override if you pull a different primary model.
# TELVM_AGENT_DEFAULT_MODEL=qwen2.5:0.5b

# Ollama one-shot pull: defaults are qwen2.5:0.5b and tinyllama in docker-compose.yml; override only if needed.
# TELVM_OLLAMA_MODEL_A=qwen2.5:0.5b
# TELVM_OLLAMA_MODEL_B=tinyllama

# Goose CLI container (see docs/quickstart.md): Compose sets OLLAMA_HOST=http://ollama:11434; config persists in volume goose_config.
# Optional default model after `goose configure` (provider-specific; see Goose release notes).
# GOOSE_DEFAULT_MODEL=

# Compose project name used when discovering closed-agent containers on Machines (default telvm).
# TELVM_COMPOSE_PROJECT=telvm

# Set on companion for noisier Basic soak errors (curl -v); unset for normal operation.
# TELVM_CLOSED_SOAK_VERBOSE=1

# VM manager pre-flight lab (optional overrides; compose sets network + alias by default).
# TELVM_LAB_DOCKER_NETWORK=telvm_default
# TELVM_LAB_DNS_ALIAS=telvm-lab-workload
# TELVM_LAB_IMAGE=node:22-alpine
# TELVM_LAB_EXPOSED_PORT=3333
# For registry-backed images with their own CMD/ENTRYPOINT (e.g. ghcr.io/.../telvm-go-http-lab:main):
# TELVM_LAB_USE_IMAGE_CMD=1
# Private GHCR: docker login ghcr.io on the host that owns docker.sock (same Engine as the companion).

# Optional: pre-fills the "Go HTTP lab" image field on the Machines tab (no container restart needed to edit in UI).
# TELVM_GO_HTTP_LAB_IMAGE=ghcr.io/your-org/telvm-go-http-lab:main

# Network agent (PowerShell ICS service on the Windows gateway PC).
# Default is http://host.docker.internal:9225 (baked into docker-compose.yml).
# Override only if the agent runs on a different host or port.
# TELVM_NETWORK_AGENT_URL=http://host.docker.internal:9225
# TELVM_NETWORK_AGENT_TOKEN=

# Bearer token companion sends when probing telvm-node-agent on LAN hosts (:9100).
# Must match each Linux agent's --token. Dev default is test123 if unset.
# TELVM_ZIG_NODE_PROBE_TOKEN=

# Optional static cluster list for future ClusterNodePoller wiring — NOT read by
# runtime.exs today; poller is not supervised. Prefer TELVM_NETWORK_AGENT_URL + node agent.
# TELVM_CLUSTER_NODES=[{"url":"http://10.10.10.11:9100","name":"node-1"}]
# TELVM_CLUSTER_TOKEN=

# Egress proxy: defaults are enabled in docker-compose.yml (TELVM_EGRESS_ENABLED + TELVM_EGRESS_WORKLOADS).
# Override only for extra workloads, different ports, or authorization_env (API key header from an OS env var — never Postgres).
# TELVM_EGRESS_WORKLOADS=[{"id":"closed_claude","port":4001,"allow_hosts":["api.anthropic.com",".anthropic.com","deb.debian.org","security.debian.org",".debian.org"],"authorization_env":"ANTHROPIC_API_KEY"}]
# TELVM_EGRESS_WORKLOADS_FILE=/run/secrets/telvm_egress_workloads.json
